# Droplet environment file for systemd service
# Target path on droplet: /etc/onetagumvision/onetagumvision.env

DJANGO_SETTINGS_MODULE=gistagum.settings
DJANGO_SECRET_KEY=change-me-production-secret
DEBUG=false

PRIMARY_DOMAIN=onetagumvision.com
ALLOWED_HOSTS=onetagumvision.com,www.onetagumvision.com
CSRF_TRUSTED_ORIGINS=https://onetagumvision.com,https://www.onetagumvision.com

# Droplet app + PostgreSQL on same host
DATABASE_URL=postgresql://gistagum_user:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/gistagum

# Force password-reset links to use your public domain (recommended on Droplet)
PASSWORD_RESET_DOMAIN=onetagumvision.com
PASSWORD_RESET_USE_HTTPS=true

USE_SPACES=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=https://sgp1.digitaloceanspaces.com
AWS_S3_REGION_NAME=sgp1
AWS_S3_CUSTOM_DOMAIN=

# SMTP (required for forgot password emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_HOST_USER=your-smtp-user@example.com
EMAIL_HOST_PASSWORD=your-smtp-password-or-app-password
EMAIL_PORT=587
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@onetagumvision.com
